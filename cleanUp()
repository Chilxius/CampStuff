void cleanUp()
{
  for( int i = 0; i < enemies.size(); i++ )
    if( enemies.get(i).dead )
      enemies.remove(i);
      
  for( int i = 0; i < lasers.size(); i++ )
    if( lasers.get(i).dead )
      lasers.remove(i);
      
  for( int i = 0; i < explosions.size(); i++ )
    if( explosions.get(i).timer < 0 )
      explosions.remove(i);
}
